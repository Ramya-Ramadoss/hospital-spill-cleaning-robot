    <!-- Segment after Patient Room 2 door -->
    <model name="wall_corridor_bottom_seg4">
      <static>true</static>
      <pose>6.75 -1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>6.5 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>6.5 0.2 2.5</size></box></geometry>
          <material>
