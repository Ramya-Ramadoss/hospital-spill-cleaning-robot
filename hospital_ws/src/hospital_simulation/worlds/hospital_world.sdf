            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>


    <!-- ============================================================ -->
    <!-- CORRIDOR / BOTTOM-ROOM SEPARATION WALL (Y = -1)                -->
    <!-- Gaps left for doorways into ICU Room, Patient Room 1,         -->
    <!-- and Patient Room 2                                            -->
    <!-- ============================================================ -->

    <!-- Segment in front of ICU Room -->
    <model name="wall_corridor_bottom_seg1">
      <static>true</static>
      <pose>-8.5 -1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>3 0.2 2.5</size></box></geometry>
