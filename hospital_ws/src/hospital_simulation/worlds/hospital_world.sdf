      </link>
    </model>

    <!-- Segment between Reception door and Waiting Area door -->
    <model name="wall_corridor_top_seg2">
      <static>true</static>
      <pose>-2.25 1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>4.5 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>4.5 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
