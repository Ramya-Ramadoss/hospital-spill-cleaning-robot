        </visual>
      </link>
    </model>

    <!-- Segment between Waiting Area door and Nurse Station door -->
    <model name="wall_corridor_top_seg3">
      <static>true</static>
      <pose>3.75 1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>4.5 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>4.5 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Segment after Nurse Station door -->
    <model name="wall_corridor_top_seg4">
      <static>true</static>
      <pose>8.75 1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>2.5 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2.5 0.2 2.5</size></box></geometry>
