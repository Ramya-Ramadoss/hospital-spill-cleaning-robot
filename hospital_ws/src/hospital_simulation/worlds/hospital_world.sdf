    <!-- ============================================================ -->
    <!-- OBSTACLES: TABLES (2 total)                                    -->
    <!-- One in Waiting Area, one in Reception Area                     -->
    <!-- Size: 1.2 x 0.8 x 0.75 m                                       -->
    <!-- ============================================================ -->

    <model name="table_waiting_area">
      <static>true</static>
      <pose>-1 5 0.375 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.2 0.8 0.75</size></box></geometry>
