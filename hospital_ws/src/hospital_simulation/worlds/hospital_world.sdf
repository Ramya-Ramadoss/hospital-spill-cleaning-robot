    <!-- ============================================================ -->
    <!-- INTERNAL DIVIDING WALLS - TOP ROW                              -->
    <!-- Separates Reception | Waiting Area | Nurse Station            -->
    <!-- ============================================================ -->

    <!-- Wall between Reception Area and Waiting Area -->
    <model name="wall_divider_reception_waiting">
      <static>true</static>
      <pose>-4 4.25 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.2 6.5 2.5</size></box></geometry>
