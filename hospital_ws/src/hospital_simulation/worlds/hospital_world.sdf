    <!-- OBSTACLES: HOSPITAL BEDS (4 total)                             -->
    <!-- Located in ICU Room and Patient Rooms 1 & 2                    -->
    <!-- Size: 2.0 x 1.0 x 0.5 m                                        -->
    <!-- ============================================================ -->

    <!-- ICU Room - Bed 1 -->
