
<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="hospital_world">

    <!-- ============================================================ -->
    <!-- PHYSICS & PLUGINS (required for Gazebo Harmonic gz sim)       -->
    <!-- ============================================================ -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin
        filename="gz-sim-physics-system"
        name="gz::sim::systems::Physics">
    </plugin>
    <plugin
        filename="gz-sim-user-commands-system"
        name="gz::sim::systems::UserCommands">
    </plugin>
    <plugin
        filename="gz-sim-scene-broadcaster-system"
        name="gz::sim::systems::SceneBroadcaster">
    </plugin>
    <plugin
        filename="gz-sim-sensors-system"
        name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ============================================================ -->
    <!-- SCENE (background color and ambient lighting)                -->
    <!-- ============================================================ -->
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ============================================================ -->
    <!-- LIGHTING                                                       -->
    <!-- ============================================================ -->

    <!-- Main sun (directional light) -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -0.9</direction>
      <attenuation>
        <range>50</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
    </light>

    <!-- Indoor point light - top half of building -->
    <light type="point" name="indoor_light_top">
      <pose>0 4 4 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>25</range>
        <constant>0.5</constant>
        <linear>0.05</linear>
        <quadratic>0.002</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- Indoor point light - bottom half of building -->
    <light type="point" name="indoor_light_bottom">
      <pose>0 -4 4 0 0 0</pose>
      <diffuse>1 1 1 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>25</range>
        <constant>0.5</constant>
        <linear>0.05</linear>
        <quadratic>0.002</quadratic>
      </attenuation>
      <cast_shadows>false</cast_shadows>
    </light>

    <!-- ============================================================ -->
    <!-- FLOOR PLANE (22m x 17m, slightly larger than the building)    -->
    <!-- ============================================================ -->
    <model name="hospital_floor">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="floor_link">
        <collision name="floor_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>22 17</size>
            </plane>
          </geometry>
        </collision>
        <visual name="floor_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>22 17</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- BUILDING LAYOUT OVERVIEW                                       -->
    <!--                                                                -->
    <!-- Building footprint: 20m (X) x 15m (Y), centered at origin     -->
    <!-- X range: -10 to 10 | Y range: -7.5 to 7.5                     -->
    <!--                                                                -->
    <!-- Central horizontal corridor: Y = -1 to 1 (2m wide)            -->
    <!--                                                                -->
    <!-- TOP ROW (Y: 1 to 7.5)                                          -->
    <!--   Reception Area : X -10 to -4                                 -->
    <!--   Waiting Area   : X  -4 to  2                                 -->
    <!--   Nurse Station  : X   2 to 10                                 -->
    <!--                                                                -->
    <!-- BOTTOM ROW (Y: -7.5 to -1)                                     -->
    <!--   ICU Room       : X -10 to -3                                 -->
    <!--   Patient Room 1 : X  -3 to 3.5                                -->
    <!--   Patient Room 2 : X 3.5 to 10                                 -->
    <!--                                                                -->
    <!-- All walls: thickness 0.2m, height 2.5m                        -->
    <!-- ============================================================ -->


    <!-- ============================================================ -->
    <!-- OUTER PERIMETER WALLS                                          -->
    <!-- ============================================================ -->

    <!-- North outer wall -->
    <model name="wall_outer_north">
      <static>true</static>
      <pose>0 7.5 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>20 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>20 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- South outer wall -->
    <model name="wall_outer_south">
      <static>true</static>
      <pose>0 -7.5 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>20 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>20 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- West outer wall -->
    <model name="wall_outer_west">
      <static>true</static>
      <pose>-10 0 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.2 15 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.2 15 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- East outer wall -->
    <model name="wall_outer_east">
      <static>true</static>
      <pose>10 0 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.2 15 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.2 15 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>


    <!-- ============================================================ -->
    <!-- CORRIDOR / TOP-ROOM SEPARATION WALL (Y = 1)                    -->
    <!-- Gaps left for doorways into Reception, Waiting Area,           -->
    <!-- and Nurse Station                                             -->
    <!-- ============================================================ -->

    <!-- Segment in front of Reception Area -->
    <model name="wall_corridor_top_seg1">
      <static>true</static>
      <pose>-8 1 1.25 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>4 0.2 2.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>4 0.2 2.5</size></box></geometry>
          <material>
            <ambient>0.85 0.85 0.85 1</ambient>
            <diffuse>0.85 0.85 0.85 1</diffuse>
          </material>
